{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "remarkup",
  "rules": {
    "document": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_chunk"
      }
    },
    "_chunk": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "heading"
        },
        {
          "type": "SYMBOL",
          "name": "callout"
        },
        {
          "type": "SYMBOL",
          "name": "italic"
        },
        {
          "type": "SYMBOL",
          "name": "revision_link"
        },
        {
          "type": "SYMBOL",
          "name": "task_link"
        },
        {
          "type": "SYMBOL",
          "name": "file_embed"
        },
        {
          "type": "SYMBOL",
          "name": "paste_embed"
        },
        {
          "type": "SYMBOL",
          "name": "user_mention"
        },
        {
          "type": "SYMBOL",
          "name": "text"
        },
        {
          "type": "SYMBOL",
          "name": "newline"
        }
      ]
    },
    "italic": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "\\/\\/[^\\/\\n]+\\/\\/"
      }
    },
    "revision_link": {
      "type": "PATTERN",
      "value": "D\\d+"
    },
    "task_link": {
      "type": "PATTERN",
      "value": "T\\d+"
    },
    "file_embed": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{F"
        },
        {
          "type": "IMMEDIATE_TOKEN",
          "content": {
            "type": "PATTERN",
            "value": "\\d+"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "IMMEDIATE_TOKEN",
              "content": {
                "type": "PATTERN",
                "value": "[^}]*"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "IMMEDIATE_TOKEN",
          "content": {
            "type": "STRING",
            "value": "}"
          }
        }
      ]
    },
    "paste_embed": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{P"
        },
        {
          "type": "IMMEDIATE_TOKEN",
          "content": {
            "type": "PATTERN",
            "value": "\\d+"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "IMMEDIATE_TOKEN",
              "content": {
                "type": "PATTERN",
                "value": "[^}]*"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "IMMEDIATE_TOKEN",
          "content": {
            "type": "STRING",
            "value": "}"
          }
        }
      ]
    },
    "user_mention": {
      "type": "PATTERN",
      "value": "@[a-zA-Z0-9_.-]+"
    },
    "callout": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "NOTE"
            },
            {
              "type": "STRING",
              "value": "WARNING"
            },
            {
              "type": "STRING",
              "value": "IMPORTANT"
            },
            {
              "type": "STRING",
              "value": "TODO"
            }
          ]
        },
        {
          "type": "STRING",
          "value": ":"
        }
      ]
    },
    "heading": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "={2,} +[^=\\n]+? +={2,}"
      }
    },
    "text": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "[a-zA-Z0-9_]+"
        },
        {
          "type": "TOKEN",
          "content": {
            "type": "PREC",
            "value": -1,
            "content": {
              "type": "PATTERN",
              "value": "."
            }
          }
        }
      ]
    },
    "newline": {
      "type": "STRING",
      "value": "\n"
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}